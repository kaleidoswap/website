{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "website",
	"main": "worker/index.ts",
	"compatibility_date": "2025-04-01",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS",
		"not_found_handling": "single-page-application"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "kaleidoswap-website",
			"database_id": "a0d53b77-af58-4478-b936-40cdff6a4c62",
			"migrations_dir": "migrations"
		}
	]
}
