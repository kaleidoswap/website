# Frontend env vars (Vite picks these up at build time)

# Cloudflare Turnstile site key for the Rate beta signup form.
# Get it from https://dash.cloudflare.com → Turnstile.
VITE_TURNSTILE_SITE_KEY=

# Optional: override the canonical site URL used in <SEO>.
# VITE_SITE_URL=https://kaleidoswap.com
